---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Dr. Jutta Meise – Autorin. Deutsch & Englisch.', image = '/portrait.jpg' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const showDevCredit = true; // auf false setzen falls Kundin keinen Entwicklerhinweis wünscht

const nav = [
  { href: '/',                    label: 'Start' },
  { href: '/ueber-die-autorin',   label: 'Über die Autorin' },
  { href: '/buecher',             label: 'Bücher' },
  { href: '/veroeffentlichungen', label: 'Veröffentlichungen' },
  { href: '/veranstaltungen',     label: 'Veranstaltungen' },
  { href: '/kontakt',             label: 'Kontakt' },
];

const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalURL} />
  <meta name="description" content={description} />
  <!-- TEMPORÄR: vor Launch entfernen -->
  <meta name="robots" content="noindex, nofollow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={image} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />
  <slot name="head" />
  <title>{title}</title>
</head>
<body>

  <!-- Navigation -->
  <header style="background: rgba(26,31,46,0.97); backdrop-filter: blur(20px) saturate(160%);" class="sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-6 sm:px-10">
      <div class="flex items-center justify-between" style="height: 76px;">

        <!-- Wortmarke -->
        <a
          href="/"
          style="font-family: var(--font-serif); color: white; letter-spacing: 0.035em; font-size: 1.0625rem;"
          class="font-normal hover:opacity-80 transition-opacity"
        >
          Dr. Jutta Meise
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-9" aria-label="Hauptnavigation">
          {nav.map(item => (
            <a
              href={item.href}
              class:list={['nav-link', {
                active: path === item.href || (item.href !== '/' && path.startsWith(item.href))
              }]}
            >
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Mobile Toggle -->
        <button
          id="menu-btn"
          aria-label="Menü"
          aria-expanded="false"
          class="lg:hidden p-2 flex flex-col gap-1.5"
        >
          <span class="block w-5 h-px bg-white/70"></span>
          <span class="block w-5 h-px bg-white/70"></span>
          <span class="block w-3.5 h-px bg-white/70"></span>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-nav" class="hidden lg:hidden" style="background: rgba(26,31,46,0.98); backdrop-filter: blur(20px); border-top: 1px solid rgba(255,255,255,0.06);">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1">
        {nav.map(item => (
          <a href={item.href} class="nav-link text-sm" style="padding-top: 0.5rem; padding-bottom: 0.5rem; display: block;">{item.label}</a>
        ))}
      </nav>
    </div>
  </header>

  <main id="main" style="margin-top: -1px;">
    <slot />
  </main>

  <!-- Footer – editorial & minimal -->
  <footer style="background: var(--color-ink);" class="pt-20 pb-10 px-6 sm:px-10">
    <div class="max-w-6xl mx-auto">

      <!-- Oberer Teil -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-12 pb-16" style="border-bottom: 1px solid rgba(255,255,255,0.07);">

        <!-- Name & Tagline -->
        <div class="lg:col-span-2">
          <p style="font-family: var(--font-serif); color: white; font-size: clamp(1.75rem, 3vw, 2.25rem); font-weight: 400; line-height: 1.2; letter-spacing: -0.01em;">
            Dr. Jutta Meise
          </p>
          <p class="t-label mt-3" style="color: var(--color-mist);">Autorin · Deutsch & Englisch · Dinslaken</p>
          <div class="flex gap-5 mt-7">
            <a href="https://www.instagram.com/meise.jutta" target="_blank" rel="noopener noreferrer"
               style="color: rgba(255,255,255,0.4); padding: 0.375rem; margin: -0.375rem;" class="hover:text-white transition-colors" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
            <a href="https://www.facebook.com/p/Jutta-Meise-61558940223945/" target="_blank" rel="noopener noreferrer"
               style="color: rgba(255,255,255,0.4); padding: 0.375rem; margin: -0.375rem;" class="hover:text-white transition-colors" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Navigation -->
        <div>
          <p class="t-label mb-5" style="color: rgba(255,255,255,0.25);">Seiten</p>
          <nav class="flex flex-col gap-4 sm:gap-3">
            {nav.map(item => (
              <a href={item.href}
                 style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.5); padding: 0.125rem 0;"
                 class="hover:text-white transition-colors">
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </div>

      <!-- Unterer Teil -->
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3 pt-8">
        <p style="font-family: var(--font-ui); font-size: 0.75rem; color: rgba(255,255,255,0.2);">
          © {new Date().getFullYear()} Dr. Jutta Meise
        </p>
        <div style="font-family: var(--font-ui); font-size: 0.75rem;" class="flex gap-6">
          <a href="/impressum" style="color: rgba(255,255,255,0.25);" class="hover:text-white transition-colors">Impressum</a>
          <a href="/datenschutz" style="color: rgba(255,255,255,0.25);" class="hover:text-white transition-colors">Datenschutz</a>
        </div>
      </div>
      {showDevCredit && (
        <p class="mt-4 text-center">
          <a
            href="https://www.sth-digital.de"
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: var(--font-ui); font-size: 0.6875rem; color: rgba(255,255,255,0.15); text-decoration: none; letter-spacing: 0.04em;"
            class="hover:opacity-50 transition-opacity"
          >Design &amp; Entwicklung: STH Digital</a>
        </p>
      )}

    </div>
  </footer>

  <script>
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('mobile-nav');
    btn?.addEventListener('click', () => {
      const open = !nav?.classList.contains('hidden');
      nav?.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!open));
    });
  </script>

</body>
</html>
