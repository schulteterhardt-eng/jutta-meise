---
import BaseLayout from '../layouts/BaseLayout.astro';

const buecher = [
  {
    titel: 'Angekommen',
    untertitel: 'Times of Light and Darkness',
    jahr: '2024',
    seiten: '129 Seiten',
    beschreibung: 'Hanna und Robert haben sich versprochen, füreinander da zu sein – ein Leben lang. Als Robert schwer erkrankt, wird dieses Versprechen auf eine harte Probe gestellt. Mitten im Alptraum finden die beiden zurück zu den Anfängen ihrer Beziehung – bis Hanna eine Entscheidung treffen muss, die alles verändert.',
    zitat: 'Es erzählt vom Sterben, vom Tod, aber vor allem von der Liebe.',
    isbn: '978-3-000-78045-5',
    image: '/buch-angekommen.jpg',
    amazon: 'https://www.amazon.de/dp/3000780459',
    thalia: 'https://www.thalia.de/suche?sq=978-3-000-78045-5',
    neu: true,
  },
  {
    titel: 'Einäugig',
    untertitel: 'Eine ungewöhnliche Spurensuche',
    jahr: '2021',
    seiten: '',
    beschreibung: 'Hanna ist als Einzelkind aufgewachsen – und weiß doch, dass sie eine eineiige Zwillingsschwester hatte. Heidrun starb am Tag ihrer Geburt. Was wäre gewesen? Diese Frage treibt Hanna auf eine ungewöhnliche Spurensuche: nach der Frau, die sie hätte kennen können – und nach sich selbst.',
    zitat: '',
    isbn: '978-3-000-70114-6',
    image: '/buch-einaeugig.jpg',
    amazon: 'https://www.amazon.de/dp/3000701141',
    thalia: 'https://www.thalia.de/suche?sq=978-3-000-70114-6',
    neu: false,
  },
];
---

<BaseLayout
  title="Bücher – Dr. Jutta Meise"
  description="Die Bücher von Dr. Jutta Meise: Angekommen und Einäugig – Romane über Liebe, Verlust und die Suche nach sich selbst."
>

  <!-- Hero -->
  <section style="background: var(--color-ink);" class="px-8 sm:px-14 lg:px-20 pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="max-w-6xl mx-auto">
      <p class="t-label mb-8" style="color: rgba(255,255,255,0.25);">Werke</p>
      <h1 class="t-display" style="color: white; font-size: clamp(2.5rem, 5vw, 4rem);">Bücher</h1>
      <div class="rule mt-8" style="background: rgba(255,255,255,0.2);"></div>
    </div>
  </section>


  <!-- Bücher -->
  <section style="background: var(--color-parchment);" class="py-28 sm:py-40 px-8 sm:px-14 lg:px-20">
    <div class="max-w-6xl mx-auto" style="display: flex; flex-direction: column; gap: 8rem;">
      {buecher.map((buch, i) => (
        <article style={`display: grid; gap: 4rem; align-items: start;`} class="lg:grid-cols-[5fr_6fr]">

          <!-- Cover -->
          <div class={i % 2 !== 0 ? 'lg:order-2' : ''}>
            <div
              style={`aspect-ratio: 2/3; max-width: 360px; position: relative; overflow: hidden; box-shadow: 0 24px 72px rgba(0,0,0,0.2);`}
              class={i % 2 !== 0 ? 'ml-auto' : ''}
            >
              <img src={buch.image} alt={buch.titel} class="absolute inset-0 w-full h-full object-cover" />
            </div>
            {buch.neu && (
              <p class="t-label-petrol mt-5">Neuerscheinung</p>
            )}
          </div>

          <!-- Info -->
          <div class={`flex flex-col justify-center ${i % 2 !== 0 ? 'lg:order-1' : ''}`} style="padding-top: 1rem;">
            <p class="t-label-petrol mb-5">Roman · {buch.jahr}{buch.seiten ? ` · ${buch.seiten}` : ''}</p>
            <h2 class="t-heading mb-3" style="font-size: clamp(2rem, 3.5vw, 3rem);">{buch.titel}</h2>
            <p style="font-family: var(--font-body); color: var(--color-subtle); font-style: italic; font-size: 1rem; margin-bottom: 2rem;">{buch.untertitel}</p>
            <div class="rule mb-8"></div>

            {buch.zitat && (
              <blockquote style="font-family: var(--font-serif); font-size: clamp(1.0625rem, 1.5vw, 1.1875rem); font-style: italic; color: var(--color-petrol); line-height: 1.65; margin-bottom: 2rem; padding-left: 1.375rem; border-left: 1.5px solid var(--color-petrol);">
                „{buch.zitat}"
              </blockquote>
            )}

            <p class="t-prose mb-10">{buch.beschreibung}</p>

            <div style="border-top: 1px solid var(--color-sand); padding-top: 1.5rem; margin-bottom: 2rem;">
              <p class="t-label" style="margin-bottom: 0.25rem;">ISBN</p>
              <p style="font-family: var(--font-ui); font-size: 0.875rem; color: var(--color-stone); letter-spacing: 0.04em;">{buch.isbn}</p>
            </div>

            <div style="display: flex; flex-direction: column; gap: 0.75rem;">
              <p class="t-label" style="margin-bottom: 0.25rem;">Erhältlich bei</p>
              <div style="display: flex; flex-wrap: wrap; gap: 2rem; align-items: center;">
                <a
                  href={buch.amazon}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-link"
                  style="display: inline-flex; align-items: center; gap: 0.4rem;"
                >
                  Amazon
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
                <a
                  href={buch.thalia}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-link"
                  style="display: inline-flex; align-items: center; gap: 0.4rem;"
                >
                  Thalia
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>


  <!-- Stiller Abschluss -->
  <section style="background: var(--color-cream); border-top: 1px solid var(--color-sand);" class="px-8 sm:px-14 lg:px-20 py-20">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-start sm:items-end gap-8">
      <p style="font-family: var(--font-body); color: var(--color-subtle); font-style: italic; font-size: 0.9375rem;">
        Für Leseexemplare oder Presseanfragen<br />bitte direkt Kontakt aufnehmen.
      </p>
      <a href="/kontakt" class="text-link">Kontakt →</a>
    </div>
  </section>

</BaseLayout>
