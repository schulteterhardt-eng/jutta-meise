---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kontakt – Dr. Jutta Meise"
  description="Kontakt zu Dr. Jutta Meise – für Lesungsanfragen, Pressekontakt und allgemeine Anfragen."
>

  <!-- Hero -->
  <section style="background: var(--color-ink);" class="px-8 sm:px-14 lg:px-20 pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="max-w-6xl mx-auto">
      <p class="t-label mb-8" style="color: rgba(255,255,255,0.25);">Kontakt</p>
      <h1 class="t-display" style="color: white; font-size: clamp(2.5rem, 5vw, 4rem);">Schreiben Sie mir</h1>
      <div class="rule mt-8" style="background: rgba(255,255,255,0.2);"></div>
    </div>
  </section>


  <!-- Kontakt-Inhalt -->
  <section style="background: var(--color-parchment);" class="px-8 sm:px-14 lg:px-20 py-24 sm:py-32">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[2fr_3fr] gap-16 lg:gap-24 items-start">

      <!-- Foto -->
      <div>
        <div class="overflow-hidden" style="aspect-ratio: 3/4; max-width: 320px;">
          <img
            src="/portrait.jpg"
            alt="Dr. Jutta Meise"
            class="w-full h-full object-cover object-top"
          />
        </div>
      </div>

      <!-- Kontaktinfo -->
      <div>
        <p class="t-label-petrol mb-6">Direktkontakt</p>
        <h2 class="t-heading mb-6" style="font-size: clamp(1.75rem, 3vw, 2.5rem); max-width: 22ch;">
          Ich freue mich<br />auf Ihre Nachricht.
        </h2>
        <div class="rule mb-8"></div>

        <div class="prose-editorial">
          <p>
            Für Lesungsanfragen, Pressekontakt oder allgemeine Fragen erreichen Sie mich per E-Mail.
            Ich antworte in der Regel innerhalb weniger Tage.
          </p>
        </div>

        <a
          href="mailto:jutta.meise@web.de"
          class="btn-primary mt-8 inline-flex items-center gap-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
          jutta.meise@web.de
        </a>

        <!-- Social -->
        <div class="mt-12">
          <p class="t-label mb-5">Folgen</p>
          <div class="flex gap-6">
            <a
              href="https://www.instagram.com/meise.jutta/"
              target="_blank"
              rel="noopener noreferrer"
              style="font-family: var(--font-ui); font-size: 0.8125rem; color: var(--color-subtle); letter-spacing: 0.1em; text-transform: uppercase;"
              class="flex items-center gap-2.5 hover:text-[var(--color-petrol)] transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
            <a
              href="https://www.facebook.com/profile.php?id=61558940223945"
              target="_blank"
              rel="noopener noreferrer"
              style="font-family: var(--font-ui); font-size: 0.8125rem; color: var(--color-subtle); letter-spacing: 0.1em; text-transform: uppercase;"
              class="flex items-center gap-2.5 hover:text-[var(--color-petrol)] transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Facebook
            </a>
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
