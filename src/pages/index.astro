---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Dr. Jutta Meise – Autorin"
  description="Dr. Jutta Meise – Autorin auf Deutsch und Englisch. Romane über Liebe, Verlust und Erinnerung."
>

  <!-- ① Cover – atmosphärisches Intro, kein Business-Hero -->
  <section class="relative overflow-hidden" style="min-height: 100svh; background: var(--color-ink);">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style="background-image: url('/hero.jpg');"
      aria-hidden="true"
    ></div>
    <div class="hero-overlay absolute inset-0" aria-hidden="true"></div>

    <div class="relative z-10 flex flex-col justify-end h-full px-8 sm:px-14 lg:px-20 pb-16 sm:pb-24" style="min-height: 100svh;">
      <div class="max-w-3xl">
        <p class="t-label mb-8" style="color: var(--color-fog);">Autorin · Dinslaken am Niederrhein</p>
        <h1 class="t-display text-white mb-6" style="font-size: clamp(2.5rem, 6vw, 4.5rem);">
          Zwischen Sprache,<br />Erinnerung<br />und Leben.
        </h1>
        <div class="rule mb-7" style="background: rgba(255,255,255,0.35);"></div>
        <p style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.55); letter-spacing: 0.16em; text-transform: uppercase;">
          Dr. Jutta Meise &nbsp;·&nbsp; Deutsch &amp; Englisch &nbsp;·&nbsp; Veröffentlichungen
        </p>
      </div>
    </div>

    <!-- Scroll-Hinweis -->
    <div class="absolute bottom-8 right-10 hidden sm:flex flex-col items-center gap-3" aria-hidden="true">
      <div style="width: 1px; height: 60px; background: rgba(255,255,255,0.2);"></div>
      <p style="font-family: var(--font-ui); font-size: 0.625rem; color: rgba(255,255,255,0.3); letter-spacing: 0.2em; text-transform: uppercase; writing-mode: vertical-rl;">Scrollen</p>
    </div>
  </section>


  <!-- ② Erstes Buch – editorial, Bild dominant -->
  <section style="background: var(--color-parchment);" class="overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[5fr_4fr] items-stretch" style="min-height: 70vh;">

      <!-- Buchcover -->
      <div class="relative" style="background: var(--color-deep); min-height: 400px;">
        <img src="/buch-angekommen.jpg" alt="Angekommen" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0 flex items-end p-10 sm:p-14">
          <div>
            <p class="t-label mb-3" style="color: var(--color-fog);">Roman · 2024</p>
            <p style="font-family: var(--font-serif); font-size: clamp(2rem, 4vw, 3rem); color: white; font-weight: 400; line-height: 1.15; letter-spacing: -0.01em;">
              Angekommen
            </p>
            <p style="font-family: var(--font-body); font-size: 0.9375rem; color: rgba(255,255,255,0.5); font-style: italic; margin-top: 0.375rem;">
              Times of Light and Darkness
            </p>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div class="flex flex-col justify-center px-10 sm:px-14 lg:px-16 py-16">
        <p class="t-label-petrol mb-6">Neuerscheinung</p>
        <p style="font-family: var(--font-serif); font-size: clamp(1.125rem, 2vw, 1.375rem); color: var(--color-ink); line-height: 1.65; font-style: italic;">
          „Es erzählt vom Sterben, vom Tod, aber vor allem von der Liebe."
        </p>
        <div class="rule my-8"></div>
        <p class="t-prose">
          Hanna und Robert versprechen einander, ein Leben lang füreinander da zu sein.
          Als Robert schwer erkrankt, wird dieses Versprechen zur schwersten Prüfung —
          und zur tiefsten Bewährung ihrer Liebe.
        </p>
        <a href="/buecher" class="text-link mt-10 self-start">Zum Buch</a>
      </div>
    </div>
  </section>


  <!-- ③ Großes Zitat – typografische Sektion -->
  <section style="background: var(--color-ink);" class="px-8 sm:px-14 lg:px-20 py-28 sm:py-36">
    <div class="max-w-4xl">
      <p class="t-label mb-8" style="color: rgba(255,255,255,0.25);">Rezension</p>
      <blockquote class="t-quote" style="color: white; font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.35;">
        „Ich schreibe, weil manche Dinge<br class="hidden sm:block" />
        nur in der Sprache wirklich ankommen."
      </blockquote>
      <p style="font-family: var(--font-ui); font-size: 0.75rem; color: rgba(255,255,255,0.3); letter-spacing: 0.16em; text-transform: uppercase; margin-top: 2rem;">
        Dr. Jutta Meise
      </p>
    </div>
  </section>


  <!-- ④ Zweites Buch – gegenläufiges Layout -->
  <section style="background: var(--color-cream);" class="overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[4fr_5fr] items-stretch" style="min-height: 60vh;">

      <!-- Text -->
      <div class="flex flex-col justify-center px-10 sm:px-14 lg:px-16 py-16 order-2 lg:order-1">
        <p class="t-label-petrol mb-6">Roman · 2021</p>
        <h2 class="t-heading mb-5" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">
          Einäugig
        </h2>
        <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-subtle); font-style: italic; margin-bottom: 1.5rem;">
          Eine ungewöhnliche Spurensuche
        </p>
        <div class="rule mb-7"></div>
        <p class="t-prose">
          Hanna wuchs als Einzelkind auf — und weiß doch, dass sie eine eineiige Zwillingsschwester hatte.
          Heidrun starb am Tag ihrer Geburt. Was wäre gewesen?
          Eine Spurensuche, die mehr freilegt als erwartet.
        </p>
        <a href="/buecher" class="text-link mt-10 self-start">Zum Buch</a>
      </div>

      <!-- Buchcover -->
      <div class="relative order-1 lg:order-2" style="background: var(--color-deep); min-height: 360px;">
        <img src="/buch-einaeugig.jpg" alt="Einäugig" class="absolute inset-0 w-full h-full object-cover" />
        <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--color-deep) 0%, #1a3040 100%);"></div>
        <div class="absolute bottom-10 left-10 right-10">
          <div class="rule mb-5"></div>
          <p class="t-label" style="color: rgba(255,255,255,0.4);">ISBN 978-3-000-70114-6</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ⑤ Über die Autorin – persönlich, nicht biographisch-trocken -->
  <section style="background: var(--color-parchment);" class="px-8 sm:px-14 lg:px-20 py-28 sm:py-36 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[3fr_2fr] gap-16 lg:gap-24 items-center">

      <!-- Text -->
      <div>
        <p class="t-label-petrol mb-8">Über die Autorin</p>
        <h2 class="t-heading mb-8" style="font-size: clamp(2rem, 3.5vw, 3rem); max-width: 20ch;">
          Eine Stimme,<br />die sich Zeit nimmt.
        </h2>
        <div class="rule mb-8"></div>
        <p class="t-prose" style="max-width: 50ch;">
          Dr. Jutta Meise, geboren 1958 in Duisburg, lebte lange mit der Sprache als Lehrerin —
          Deutsch und Englisch, mehr als zwei Jahrzehnte an Gymnasien in NRW.
          Erst nach dem Verlust nahestehender Menschen begann sie zu schreiben.
          Nicht für ein Publikum. Sondern weil es notwendig war.
        </p>
        <a href="/ueber-die-autorin" class="text-link mt-10 inline-block">Mehr über Jutta Meise</a>
      </div>

      <!-- Foto -->
      <div class="relative">
        <div class="overflow-hidden" style="aspect-ratio: 3/4; max-width: 340px; margin-left: auto;">
          <img
            src="/portrait.jpg"
            alt="Dr. Jutta Meise"
            class="w-full h-full object-cover object-top"
          />
        </div>
        <!-- Dekorative Linie -->
        <div
          class="absolute hidden lg:block"
          style="width: 1px; height: 80px; background: var(--color-sand); top: -40px; right: -20px;"
          aria-hidden="true"
        ></div>
      </div>
    </div>
  </section>


  <!-- ⑥ Ruhiger Abschluss – kein aggressiver CTA -->
  <section style="background: var(--color-deep); border-top: 1px solid rgba(255,255,255,0.05);" class="px-8 sm:px-14 lg:px-20 py-24">
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row justify-between items-start lg:items-end gap-12">

      <div>
        <p class="t-label mb-5" style="color: rgba(255,255,255,0.25);">Kontakt</p>
        <p style="font-family: var(--font-serif); font-size: clamp(1.25rem, 2.5vw, 1.75rem); color: white; font-weight: 400; line-height: 1.4;">
          Für Lesungsanfragen<br />und Pressekontakt.
        </p>
        <a
          href="mailto:jutta.meise@web.de"
          style="font-family: var(--font-body); color: var(--color-mist); font-style: italic; font-size: 1rem;"
          class="inline-block mt-5 hover:text-white transition-colors"
        >
          jutta.meise@web.de
        </a>
      </div>

      <div class="flex flex-col gap-5 items-start lg:items-end">
        <p class="t-label" style="color: rgba(255,255,255,0.25);">Folgen</p>
        <div class="flex gap-6">
          <a
            href="https://www.instagram.com/meise.jutta/"
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.45); letter-spacing: 0.1em; text-transform: uppercase;"
            class="flex items-center gap-2.5 hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Instagram
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=61558940223945"
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.45); letter-spacing: 0.1em; text-transform: uppercase;"
            class="flex items-center gap-2.5 hover:text-white transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Facebook
          </a>
        </div>
        <a href="/buecher" class="text-link" style="color: rgba(255,255,255,0.3);">Alle Bücher ansehen</a>
      </div>

    </div>
  </section>

</BaseLayout>
