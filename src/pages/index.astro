---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Dr. Jutta Meise – Autorin"
  description="Dr. Jutta Meise – Autorin auf Deutsch und Englisch. Romane über Liebe, Verlust und Erinnerung. Pensionierte Lehrerin aus Dinslaken am Niederrhein."
  image="/portrait.jpg"
>

<style>
  /* ── Keyframes ──────────────────────────────────────────── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes hero-drift {
    0%, 100% { transform: scale(1.05) translateY(0); }
    50%       { transform: scale(1.00) translateY(-0.8%); }
  }
  .hero-bg {
    transform-origin: 55% 15%;
    animation: hero-drift 26s ease-in-out infinite;
    will-change: transform;
  }
  .hero-mobile-portrait {
    height: 55vw;
    max-height: 320px;
  }

  /* ── Hero: gestaffelt beim Laden ────────────────────────── */
  .hero-label  { animation: fade-up  0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.25s both; }
  .hero-h1     { animation: fade-up  1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.50s both; }
  .hero-rule   { animation: fade-in  0.8s ease                                  0.95s both; }
  .hero-byline { animation: fade-up  0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) 1.10s both; }
  .hero-cta    { animation: fade-up  0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) 1.35s both; }

  /* ── Scroll-Reveal (via IntersectionObserver) ───────────── */
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
                transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.in-view         { opacity: 1; transform: translateY(0); }
  .reveal-d1              { transition-delay: 0.1s; }
  .reveal-d2              { transition-delay: 0.2s; }
  .reveal-d3              { transition-delay: 0.32s; }

  /* ── Buchcover-Hover ─────────────────────────────────────── */
  .book-cover {
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.55s ease;
  }
  .book-cover:hover {
    transform: translateY(-8px) scale(1.018);
    box-shadow: 0 40px 90px rgba(0,0,0,0.35) !important;
  }

  /* ── Portrait-Hover ──────────────────────────────────────── */
  .portrait-img {
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .portrait-img:hover { transform: scale(1.03); }

  /* ── Pressestimme ────────────────────────────────────────── */
  .press-quote {
    border-left: 2px solid var(--color-petrol);
    padding-left: 2rem;
  }

  /* ── Event-Foto ──────────────────────────────────────────── */
  .event-img {
    transition: opacity 0.4s ease;
  }
  .event-img:hover { opacity: 1 !important; }

  /* ── Mobile-Optimierungen ───────────────────────────────── */
  @media (max-width: 639px) {
    .hero-inner {
      padding-bottom: 2.5rem !important;
    }
    .social-touch {
      display: inline-flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.625rem;
      margin: -0.625rem;
    }
    .social-touch svg {
      width: 1.25rem !important;
      height: 1.25rem !important;
    }
  }

  /* ── prefers-reduced-motion ──────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-label, .hero-h1, .hero-rule, .hero-byline, .hero-cta,
    .reveal, .reveal-d1, .reveal-d2, .hero-bg {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .book-cover, .portrait-img { transition: none !important; }
  }
</style>


  <!-- ① Hero: Split-Layout -->
  <section class="hero-section" style="background: var(--color-ink);">

    <!-- Mobile: Portrait-Streifen oben -->
    <div class="lg:hidden relative overflow-hidden hero-mobile-portrait">
      <img
        src="/Jutta_meise.jpeg"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 w-full h-full object-cover"
        style="object-position: center 15%;"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(26,31,46,0.08) 0%, rgba(26,31,46,0.5) 65%, rgba(26,31,46,1) 100%);" aria-hidden="true"></div>
    </div>

    <!-- Desktop: Linke Textspalte / Rechte Portraitspalte -->
    <div class="lg:grid lg:grid-cols-[55fr_45fr]" style="min-height: 100svh;">

      <!-- Text -->
      <div class="relative z-10 flex flex-col justify-end px-8 sm:px-14 lg:px-16 xl:px-20 pb-16 sm:pb-24 pt-12 lg:pt-0 lg:min-h-screen hero-inner">
        <div class="max-w-xl">
          <p class="t-label mb-10 hero-label" style="color: var(--color-fog);">Autorin · Dinslaken am Niederrhein</p>
          <h1 class="t-display text-white mb-8 hero-h1" style="font-size: clamp(3.25rem, 7.5vw, 6rem); letter-spacing: -0.03em; line-height: 1.05;">
            Zwischen Sprache,<br />Erinnerung<br />und Leben.
          </h1>
          <div class="rule mb-9 hero-rule" style="background: rgba(255,255,255,0.3);"></div>
          <p class="hero-byline mb-10" style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.5); letter-spacing: 0.18em; text-transform: uppercase;">
            Dr. Jutta Meise &nbsp;·&nbsp; Autorin &nbsp;·&nbsp; Deutsch &amp; Englisch
          </p>
          <div class="hero-cta flex flex-wrap gap-4">
            <a href="/buecher" class="btn-primary">Meine Bücher →</a>
            <a href="/ueber-die-autorin" class="btn-ghost-light">Über die Autorin</a>
          </div>
        </div>
      </div>

      <!-- Portrait (Desktop) -->
      <div class="relative hidden lg:block overflow-hidden">
        <img
          src="/Jutta_meise.jpeg"
          alt=""
          aria-hidden="true"
          class="hero-bg absolute inset-0 w-full h-full object-cover"
          style="object-position: center 15%;"
        />
        <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(26,31,46,1) 0%, rgba(26,31,46,0.55) 22%, rgba(26,31,46,0.1) 55%, transparent 100%);" aria-hidden="true"></div>
        <div class="absolute inset-x-0 bottom-0" style="height: 35%; background: linear-gradient(to top, rgba(26,31,46,0.6) 0%, transparent 100%);" aria-hidden="true"></div>
      </div>

    </div>
  </section>


  <!-- ② Buch: Angekommen -->
  <section style="background: var(--color-parchment);" class="px-8 sm:px-14 lg:px-20 py-24 sm:py-32 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[5fr_4fr] gap-16 items-center">
      <div class="flex justify-center lg:justify-start reveal">
        <div class="book-cover" style="max-width: 280px; width: 100%; aspect-ratio: 2/3; position: relative; overflow: hidden; box-shadow: 0 24px 70px rgba(0,0,0,0.28);">
          <img src="/buch-angekommen.jpg" alt="Angekommen" class="absolute inset-0 w-full h-full object-cover" />
        </div>
      </div>
      <div class="flex flex-col justify-center reveal reveal-d2">
        <p class="t-label-petrol mb-3">Roman · 2024</p>
        <h2 class="t-heading mb-2" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">Angekommen</h2>
        <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-subtle); font-style: italic; margin-bottom: 1.5rem;">Times of Light and Darkness</p>
        <div class="rule mb-6"></div>
        <p style="font-family: var(--font-serif); font-size: clamp(1rem, 1.5vw, 1.125rem); color: var(--color-ink); line-height: 1.65; font-style: italic; margin-bottom: 1.25rem;">
          „Es erzählt vom Sterben, vom Tod, aber vor allem von der Liebe."
        </p>
        <p class="t-prose mb-8">Hanna und Robert versprechen einander, ein Leben lang füreinander da zu sein. Als Robert schwer erkrankt, wird dieses Versprechen zur schwersten Prüfung — und zur tiefsten Bewährung ihrer Liebe.</p>
        <div class="flex flex-wrap gap-5 items-center">
          <a href="/buecher" class="text-link">Mehr erfahren</a>
          <a href="https://www.amazon.de/dp/3000780459" target="_blank" rel="noopener noreferrer" class="btn-primary">Bei Amazon →</a>
        </div>
      </div>
    </div>
  </section>


  <!-- ③ Großes Zitat – typografische Sektion -->
  <section style="background: var(--color-ink);" class="px-8 sm:px-14 lg:px-20 py-32 sm:py-40 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-end">

      <div class="flex justify-center items-end reveal">
        <img
          src="/katze-zitat.png"
          alt=""
          aria-hidden="true"
          style="max-height: clamp(80px, 14vw, 200px); width: auto; opacity: 0.45; filter: brightness(0.75);"
        />
      </div>

      <div class="reveal reveal-d2">
        <p class="t-label mb-8" style="color: rgba(255,255,255,0.22);">In eigenen Worten</p>
        <blockquote class="t-quote" style="color: white; font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.35;">
          „Ich schreibe, weil manche Dinge<br class="hidden sm:block" />
          nur in der Sprache wirklich ankommen."
        </blockquote>
        <p style="font-family: var(--font-ui); font-size: 0.75rem; color: rgba(255,255,255,0.28); letter-spacing: 0.18em; text-transform: uppercase; margin-top: 2.5rem;">
          Dr. Jutta Meise
        </p>
      </div>
    </div>
  </section>


  <!-- ④ Buch: Einäugig -->
  <section style="background: var(--color-cream);" class="px-8 sm:px-14 lg:px-20 py-24 sm:py-32 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[4fr_5fr] gap-16 items-center">
      <div class="flex justify-center lg:justify-start order-1 lg:order-2 reveal">
        <div class="book-cover" style="max-width: 280px; width: 100%; aspect-ratio: 2/3; position: relative; overflow: hidden; box-shadow: 0 24px 70px rgba(0,0,0,0.22);">
          <img src="/buch-einaeugig.jpg" alt="Einäugig" class="absolute inset-0 w-full h-full object-cover" />
        </div>
      </div>
      <div class="flex flex-col justify-center order-2 lg:order-1 reveal reveal-d2">
        <p class="t-label-petrol mb-3">Roman · 2021</p>
        <h2 class="t-heading mb-2" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">Einäugig</h2>
        <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-subtle); font-style: italic; margin-bottom: 1.5rem;">Eine ungewöhnliche Spurensuche</p>
        <div class="rule mb-7"></div>
        <p class="t-prose mb-8">Hanna wuchs als Einzelkind auf — und weiß doch, dass sie eine eineiige Zwillingsschwester hatte. Heidrun starb am Tag ihrer Geburt. Was wäre gewesen? Eine Spurensuche, die mehr freilegt als erwartet.</p>
        <div class="flex flex-wrap gap-5 items-center">
          <a href="/buecher" class="text-link">Mehr erfahren</a>
          <a href="https://www.amazon.de/dp/3000701141" target="_blank" rel="noopener noreferrer" class="btn-primary">Bei Amazon →</a>
        </div>
      </div>
    </div>
  </section>


  <!-- ⑤ Pressestimme -->
  <section style="background: var(--color-parchment); border-top: 1px solid var(--color-sand);" class="px-8 sm:px-14 lg:px-20 py-24 overflow-hidden">
    <div class="max-w-4xl mx-auto reveal">
      <p class="t-label mb-10">Pressestimme</p>
      <div class="press-quote">
        <blockquote class="t-quote" style="font-size: clamp(1.125rem, 2vw, 1.5rem); line-height: 1.7; color: var(--color-ink);">
          „Es erzählt vom Sterben, vom Tod, aber vor allem von der Liebe —
          und bietet dem Leser Perspektiven. Das Band zu denjenigen, die gegangen sind,
          soll nicht abreißen. Aufgeben ist für die Autorin keine Option."
        </blockquote>
        <p class="t-label mt-8" style="color: var(--color-petrol);">
          Renate Quecke · Malerin und Autorin · Dezember 2024
        </p>
      </div>
    </div>
  </section>


  <!-- ⑥ Über die Autorin -->
  <section style="background: var(--color-cream);" class="px-8 sm:px-14 lg:px-20 py-32 sm:py-40 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[3fr_2fr] gap-16 lg:gap-24 items-center">

      <div class="reveal">
        <p class="t-label-petrol mb-8">Über die Autorin</p>
        <h2 class="t-heading mb-8" style="font-size: clamp(2rem, 3.5vw, 3rem); max-width: 20ch;">
          Eine Stimme,<br />die sich Zeit nimmt.
        </h2>
        <div class="rule mb-8"></div>
        <p class="t-prose mb-3" style="max-width: 50ch;">
          Dr. Jutta Meise, geboren 1958 in Duisburg, lebte lange mit der Sprache als Lehrerin —
          Deutsch und Englisch, mehr als zwei Jahrzehnte an einer Realschule in NRW.
          Erst nach dem Verlust nahestehender Menschen begann sie zu schreiben.
          Nicht für ein Publikum. Sondern weil es notwendig war.
        </p>
        <div class="flex flex-wrap gap-5 mt-10">
          <a href="/ueber-die-autorin" class="btn-ghost">Mehr über Jutta Meise</a>
          <a href="/kontakt" class="text-link" style="display: flex; align-items: center;">Lesungsanfrage →</a>
        </div>
      </div>

      <div class="relative reveal reveal-d2">
        <div class="overflow-hidden" style="aspect-ratio: 3/4; max-width: 340px; margin-left: auto;">
          <img
            src="/portrait.jpg"
            alt="Dr. Jutta Meise, Autorin"
            class="portrait-img w-full h-full object-cover object-top"
          />
        </div>
        <div
          class="absolute hidden lg:block"
          style="width: 1px; height: 80px; background: var(--color-sand); top: -40px; right: -20px;"
          aria-hidden="true"
        ></div>
      </div>
    </div>
  </section>


  <!-- ⑦ Veranstaltungs-Teaser -->
  <section style="background: var(--color-parchment); border-top: 1px solid var(--color-sand);" class="px-8 sm:px-14 lg:px-20 py-20 overflow-hidden">
    <div class="max-w-6xl mx-auto reveal">
      <p class="t-label mb-10">Zuletzt auf der Bühne</p>
      <div class="grid lg:grid-cols-[5fr_7fr] gap-12 items-center">
        <div class="overflow-hidden" style="max-width: 400px;">
          <img
            src="/lesung-lesezeit-1.jpg"
            alt="Lesung in der LESEZEIT, Voerde, Juli 2025"
            class="event-img w-full h-auto"
            style="opacity: 0.88;"
            loading="lazy"
          />
        </div>
        <div>
          <p class="t-label-petrol mb-3">21. Juli 2025 · Voerde</p>
          <h3 class="t-heading mb-5" style="font-size: clamp(1.25rem, 2.5vw, 1.875rem);">Lesung in der LESEZEIT</h3>
          <div class="rule mb-6"></div>
          <p class="t-prose mb-3" style="max-width: 44ch;">
            Eine Lesung mit Gespräch in der Buchhandlung LESEZEIT in Voerde —
            begleitet von Rheinischer Post und NRZ.
          </p>
          <p class="t-label mb-8" style="color: var(--color-stone);">Presse: Rheinische Post · NRZ Voerde</p>
          <a href="/veranstaltungen" class="text-link">Alle Veranstaltungen →</a>
        </div>
      </div>
    </div>
  </section>


  <!-- ⑧ Abschluss -->
  <section style="background: var(--color-deep); border-top: 1px solid rgba(255,255,255,0.05);" class="px-8 sm:px-14 lg:px-20 py-24">
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row justify-between items-start lg:items-end gap-12 reveal">

      <div>
        <p class="t-label mb-5" style="color: rgba(255,255,255,0.25);">Kontakt</p>
        <p style="font-family: var(--font-serif); font-size: clamp(1.25rem, 2.5vw, 1.75rem); color: white; font-weight: 400; line-height: 1.4;">
          Für Lesungsanfragen<br />und Pressekontakt.
        </p>
        <a
          href="mailto:jutta.meise@web.de"
          style="font-family: var(--font-body); color: var(--color-mist); font-style: italic; font-size: 1rem;"
          class="inline-block mt-5 hover:text-white transition-colors"
        >
          jutta.meise@web.de
        </a>
      </div>

      <div class="flex flex-col gap-5 items-start lg:items-end">
        <p class="t-label" style="color: rgba(255,255,255,0.25);">Folgen</p>
        <div class="flex gap-6">
          <a
            href="https://www.instagram.com/meise.jutta"
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.45); letter-spacing: 0.1em; text-transform: uppercase;"
            class="flex items-center gap-2.5 hover:text-white transition-colors social-touch"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Instagram
          </a>
          <a
            href="https://www.facebook.com/p/Jutta-Meise-61558940223945/"
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.45); letter-spacing: 0.1em; text-transform: uppercase;"
            class="flex items-center gap-2.5 hover:text-white transition-colors social-touch"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Facebook
          </a>
        </div>
        <a href="/buecher" class="text-link" style="color: rgba(255,255,255,0.3);">Alle Bücher ansehen →</a>
      </div>

    </div>
  </section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>


</BaseLayout>
