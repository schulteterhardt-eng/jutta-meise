---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Dr. Jutta Meise – Autorin"
  description="Dr. Jutta Meise – Autorin auf Deutsch und Englisch. Romane über Liebe, Verlust und Erinnerung."
>

<style>
  /* ── Keyframes ──────────────────────────────────────────── */
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* ── Hero: gestaffelt beim Laden ────────────────────────── */
  .hero-label  { animation: fade-up  0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.25s both; }
  .hero-h1     { animation: fade-up  1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) 0.50s both; }
  .hero-rule   { animation: fade-in  0.8s ease                                  0.95s both; }
  .hero-byline { animation: fade-up  0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) 1.10s both; }
  .hero-scroll { animation: fade-in  1.0s ease                                  1.50s both; }

  /* ── Scroll-Reveal (via IntersectionObserver) ───────────── */
  .reveal {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 0.85s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                transform 0.85s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .reveal.in-view         { opacity: 1; transform: translateY(0); }
  .reveal-d1              { transition-delay: 0.12s; }
  .reveal-d2              { transition-delay: 0.24s; }

  /* ── Buchcover-Hover ─────────────────────────────────────── */
  .book-cover {
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.55s ease;
  }
  .book-cover:hover {
    transform: translateY(-7px) scale(1.018);
    box-shadow: 0 36px 80px rgba(0,0,0,0.32) !important;
  }

  /* ── Mobile-Optimierungen ───────────────────────────────── */
  @media (max-width: 639px) {
    /* Hero: Nav-Höhe (64 px) abziehen – verhindert Overflow und Leerraum oben */
    .hero-section,
    .hero-inner {
      min-height: calc(100svh - 64px) !important;
    }
    .hero-inner {
      padding-bottom: 3rem !important;
    }
    /* Social-Links: mindestens 44 × 44 px Touch-Fläche */
    .social-touch {
      display: inline-flex;
      align-items: center;
      gap: 0.625rem;
      padding: 0.625rem;
      margin: -0.625rem;
    }
    .social-touch svg {
      width: 1.25rem !important;
      height: 1.25rem !important;
    }
  }

  /* ── prefers-reduced-motion ──────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .hero-label, .hero-h1, .hero-rule, .hero-byline, .hero-scroll,
    .reveal, .reveal-d1, .reveal-d2 {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .book-cover { transition: none !important; }
  }
</style>


  <!-- ① Cover – atmosphärisches Intro, kein Business-Hero -->
  <section class="relative overflow-hidden hero-section" style="min-height: 100svh; background: var(--color-ink);">
    <img
      src="/hero.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover"
      style="object-position: 70% center;"
    />
    <div class="hero-overlay absolute inset-0" aria-hidden="true"></div>

    <div class="relative z-10 flex flex-col justify-end h-full px-8 sm:px-14 lg:px-20 pb-20 sm:pb-32 hero-inner" style="min-height: 100svh;">
      <div class="max-w-3xl">
        <p class="t-label mb-10 hero-label" style="color: var(--color-fog);">Autorin · Dinslaken am Niederrhein</p>
        <h1 class="t-display text-white mb-8 hero-h1" style="font-size: clamp(3rem, 7vw, 5.5rem); letter-spacing: -0.025em; line-height: 1.08;">
          Zwischen Sprache,<br />Erinnerung<br />und Leben.
        </h1>
        <div class="rule mb-9 hero-rule" style="background: rgba(255,255,255,0.3);"></div>
        <p class="hero-byline" style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.5); letter-spacing: 0.18em; text-transform: uppercase;">
          Dr. Jutta Meise &nbsp;·&nbsp; Deutsch &amp; Englisch &nbsp;·&nbsp; Veröffentlichungen
        </p>
      </div>
    </div>

    <!-- Scroll-Hinweis -->
    <div class="absolute bottom-8 right-10 hidden sm:flex flex-col items-center gap-3 hero-scroll" aria-hidden="true">
      <div style="width: 1px; height: 60px; background: rgba(255,255,255,0.18);"></div>
      <p style="font-family: var(--font-ui); font-size: 0.625rem; color: rgba(255,255,255,0.28); letter-spacing: 0.2em; text-transform: uppercase; writing-mode: vertical-rl;">Scrollen</p>
    </div>
  </section>


  <!-- ② Erstes Buch – editorial, Bild dominant -->
  <section style="background: var(--color-parchment);" class="px-8 sm:px-14 lg:px-20 py-24 sm:py-32 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[5fr_4fr] gap-16 items-center">

      <!-- Buchcover -->
      <div class="flex justify-center lg:justify-start reveal">
        <div class="book-cover" style="max-width: 220px; width: 100%; aspect-ratio: 2/3; position: relative; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.25);">
          <img src="/buch-angekommen.jpg" alt="Angekommen" class="absolute inset-0 w-full h-full object-cover" />
        </div>
      </div>

      <!-- Text -->
      <div class="flex flex-col justify-center reveal reveal-d2">
        <p class="t-label-petrol mb-3">Roman · 2024</p>
        <h2 class="t-heading mb-2" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">Angekommen</h2>
        <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-subtle); font-style: italic; margin-bottom: 1.5rem;">Times of Light and Darkness</p>
        <div class="rule mb-6"></div>
        <p style="font-family: var(--font-serif); font-size: clamp(1rem, 1.5vw, 1.125rem); color: var(--color-ink); line-height: 1.65; font-style: italic; margin-bottom: 1rem;">
          „Es erzählt vom Sterben, vom Tod, aber vor allem von der Liebe."
        </p>
        <p class="t-prose mb-8">
          Hanna und Robert versprechen einander, ein Leben lang füreinander da zu sein.
          Als Robert schwer erkrankt, wird dieses Versprechen zur schwersten Prüfung —
          und zur tiefsten Bewährung ihrer Liebe.
        </p>
        <a href="/buecher" class="text-link self-start">Zum Buch</a>
      </div>
    </div>
  </section>


  <!-- ③ Großes Zitat – typografische Sektion -->
  <section style="background: var(--color-ink);" class="px-8 sm:px-14 lg:px-20 py-32 sm:py-40 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[1fr_2fr] gap-12 lg:gap-20 items-end">

      <!-- Katze -->
      <div class="flex justify-center items-end reveal">
        <img
          src="/katze-zitat.png"
          alt=""
          aria-hidden="true"
          style="max-height: clamp(120px, 22vw, 320px); width: auto; opacity: 0.85; filter: brightness(0.9);"
        />
      </div>

      <!-- Zitat -->
      <div class="reveal reveal-d2">
        <p class="t-label mb-8" style="color: rgba(255,255,255,0.22);">In eigenen Worten</p>
        <blockquote class="t-quote" style="color: white; font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.35;">
          „Ich schreibe, weil manche Dinge<br class="hidden sm:block" />
          nur in der Sprache wirklich ankommen."
        </blockquote>
        <p style="font-family: var(--font-ui); font-size: 0.75rem; color: rgba(255,255,255,0.28); letter-spacing: 0.18em; text-transform: uppercase; margin-top: 2.5rem;">
          Dr. Jutta Meise
        </p>
      </div>
    </div>
  </section>


  <!-- ④ Zweites Buch – gegenläufiges Layout -->
  <section style="background: var(--color-cream);" class="px-8 sm:px-14 lg:px-20 py-24 sm:py-32 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[4fr_5fr] gap-16 items-center">

      <!-- Buchcover -->
      <div class="flex justify-center lg:justify-start order-1 lg:order-2 reveal">
        <div class="book-cover" style="max-width: 220px; width: 100%; aspect-ratio: 2/3; position: relative; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.2);">
          <img src="/buch-einaeugig.jpg" alt="Einäugig" class="absolute inset-0 w-full h-full object-cover" />
        </div>
      </div>

      <!-- Text -->
      <div class="flex flex-col justify-center order-2 lg:order-1 reveal reveal-d2">
        <p class="t-label-petrol mb-6">Roman · 2021</p>
        <h2 class="t-heading mb-5" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">
          Einäugig
        </h2>
        <p style="font-family: var(--font-body); font-size: 0.9375rem; color: var(--color-subtle); font-style: italic; margin-bottom: 1.5rem;">
          Eine ungewöhnliche Spurensuche
        </p>
        <div class="rule mb-7"></div>
        <p class="t-prose">
          Hanna wuchs als Einzelkind auf — und weiß doch, dass sie eine eineiige Zwillingsschwester hatte.
          Heidrun starb am Tag ihrer Geburt. Was wäre gewesen?
          Eine Spurensuche, die mehr freilegt als erwartet.
        </p>
        <a href="/buecher" class="text-link mt-10 self-start">Zum Buch</a>
      </div>
    </div>
  </section>


  <!-- ⑤ Über die Autorin – persönlich, nicht biographisch-trocken -->
  <section style="background: var(--color-parchment);" class="px-8 sm:px-14 lg:px-20 py-32 sm:py-40 overflow-hidden">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[3fr_2fr] gap-16 lg:gap-24 items-center">

      <!-- Text -->
      <div class="reveal">
        <p class="t-label-petrol mb-8">Über die Autorin</p>
        <h2 class="t-heading mb-8" style="font-size: clamp(2rem, 3.5vw, 3rem); max-width: 20ch;">
          Eine Stimme,<br />die sich Zeit nimmt.
        </h2>
        <div class="rule mb-8"></div>
        <p class="t-prose" style="max-width: 50ch;">
          Dr. Jutta Meise, geboren 1958 in Duisburg, lebte lange mit der Sprache als Lehrerin —
          Deutsch und Englisch, mehr als zwei Jahrzehnte an einer Realschule in NRW.
          Erst nach dem Verlust nahestehender Menschen begann sie zu schreiben.
          Nicht für ein Publikum. Sondern weil es notwendig war.
        </p>
        <a href="/ueber-die-autorin" class="text-link mt-10 inline-block">Mehr über Jutta Meise</a>
      </div>

      <!-- Foto -->
      <div class="relative reveal reveal-d2">
        <div class="overflow-hidden" style="aspect-ratio: 3/4; max-width: 340px; margin-left: auto;">
          <img
            src="/portrait.jpg"
            alt="Dr. Jutta Meise"
            class="w-full h-full object-cover object-top"
          />
        </div>
        <div
          class="absolute hidden lg:block"
          style="width: 1px; height: 80px; background: var(--color-sand); top: -40px; right: -20px;"
          aria-hidden="true"
        ></div>
      </div>
    </div>
  </section>


  <!-- ⑥ Ruhiger Abschluss – kein aggressiver CTA -->
  <section style="background: var(--color-deep); border-top: 1px solid rgba(255,255,255,0.05);" class="px-8 sm:px-14 lg:px-20 py-24">
    <div class="max-w-6xl mx-auto flex flex-col lg:flex-row justify-between items-start lg:items-end gap-12 reveal">

      <div>
        <p class="t-label mb-5" style="color: rgba(255,255,255,0.25);">Kontakt</p>
        <p style="font-family: var(--font-serif); font-size: clamp(1.25rem, 2.5vw, 1.75rem); color: white; font-weight: 400; line-height: 1.4;">
          Für Lesungsanfragen<br />und Pressekontakt.
        </p>
        <a
          href="mailto:jutta.meise@web.de"
          style="font-family: var(--font-body); color: var(--color-mist); font-style: italic; font-size: 1rem;"
          class="inline-block mt-5 hover:text-white transition-colors"
        >
          jutta.meise@web.de
        </a>
      </div>

      <div class="flex flex-col gap-5 items-start lg:items-end">
        <p class="t-label" style="color: rgba(255,255,255,0.25);">Folgen</p>
        <div class="flex gap-6">
          <a
            href="https://www.instagram.com/meise.jutta"
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.45); letter-spacing: 0.1em; text-transform: uppercase;"
            class="flex items-center gap-2.5 hover:text-white transition-colors social-touch"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            Instagram
          </a>
          <a
            href="https://www.facebook.com/p/Jutta-Meise-61558940223945/"
            target="_blank"
            rel="noopener noreferrer"
            style="font-family: var(--font-ui); font-size: 0.8125rem; color: rgba(255,255,255,0.45); letter-spacing: 0.1em; text-transform: uppercase;"
            class="flex items-center gap-2.5 hover:text-white transition-colors social-touch"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Facebook
          </a>
        </div>
        <a href="/buecher" class="text-link" style="color: rgba(255,255,255,0.3);">Alle Bücher ansehen</a>
      </div>

    </div>
  </section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('in-view');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

</BaseLayout>
