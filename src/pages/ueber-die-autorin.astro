---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Über die Autorin – Dr. Jutta Meise"
  description="Dr. Jutta Meise – Autorin, Forscherin, Stimme zwischen Deutsch und Englisch. Persönliche Biografie und literarischer Hintergrund."
>

  <!-- Hero -->
  <section style="background: var(--color-ink);" class="px-8 sm:px-14 lg:px-20 pt-24 pb-20 sm:pt-32 sm:pb-28">
    <div class="max-w-6xl mx-auto">
      <p class="t-label mb-8" style="color: rgba(255,255,255,0.25);">Autorin</p>
      <h1 class="t-display" style="color: white; font-size: clamp(2.5rem, 5vw, 4rem);">Über die Autorin</h1>
      <div class="rule mt-8" style="background: rgba(255,255,255,0.2);"></div>
    </div>
  </section>


  <!-- Portrait & Bio -->
  <section style="background: var(--color-parchment);" class="py-24 sm:py-32 px-8 sm:px-14 lg:px-20">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-[2fr_3fr] gap-16 lg:gap-24 items-start">

      <!-- Bild -->
      <div>
        <div class="overflow-hidden" style="aspect-ratio: 3/4; max-width: 320px;">
          <img src="/portrait.jpg" alt="Dr. Jutta Meise" class="w-full h-full object-cover object-top" />
        </div>
        <div class="mt-7">
          <p style="font-family: var(--font-serif); color: var(--color-ink); font-size: 1rem;">Dr. Jutta Meise</p>
          <p class="t-label-petrol mt-1">Autorin · Deutsch &amp; Englisch</p>
          <div class="flex gap-4 mt-5">
            <a href="https://www.instagram.com/meise.jutta/" target="_blank" rel="noopener noreferrer"
               style="color: var(--color-stone);" class="hover:text-[var(--color-petrol)] transition-colors" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61558940223945" target="_blank" rel="noopener noreferrer"
               style="color: var(--color-stone);" class="hover:text-[var(--color-petrol)] transition-colors" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Text -->
      <div>
        <p class="t-label-petrol mb-6">Biografie</p>
        <h2 class="t-heading mb-6" style="font-size: clamp(1.75rem, 3vw, 2.5rem); max-width: 22ch;">
          Zwischen Sprache,<br />Forschung und Literatur
        </h2>
        <div class="rule mb-8"></div>
        <div class="prose-editorial">
          <p>
            Dr. Jutta Meise, geboren 1958 in Duisburg, wuchs am Niederrhein auf. Der frühe Verlust ihrer Mutter hat sie geprägt – und die Sprache wurde ihr zu einem Ort der Verarbeitung, der Erinnerung und der Suche.
          </p>
          <p>
            Nach dem Studium der Fächer Deutsch und Englisch promovierte sie über Lessings Verhältnis zur englischen Kultur. Mehr als zwei Jahrzehnte lang unterrichtete sie als Lehrerin an Gymnasien in Nordrhein-Westfalen – bis zu ihrer Pensionierung 2020.
          </p>
          <p>
            Erst nach dem Tod nahestehender Menschen begann sie zu schreiben – zuerst für sich, dann für andere. 2020 besuchte sie Kurse in „Prosa schreiben" und „Autobiografisches Schreiben". Ein Jahr später erschien ihr erster Roman <em>Einäugig</em>, 2024 folgte <em>Angekommen</em>.
          </p>
          <p>
            Jutta Meise lebt in Dinslaken am Niederrhein, hat zwei erwachsene Kinder und zwei Katzen.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- Zitat -->
  <section style="background: var(--color-ink);" class="px-8 sm:px-14 lg:px-20 py-28 sm:py-36">
    <div class="max-w-4xl">
      <p class="t-label mb-8" style="color: rgba(255,255,255,0.25);">In eigenen Worten</p>
      <blockquote class="t-quote text-white" style="font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.35;">
        „Ich schreibe, weil manche Dinge<br class="hidden sm:block" />
        nur in der Sprache wirklich ankommen."
      </blockquote>
      <p class="t-label mt-8" style="color: rgba(255,255,255,0.3);">Dr. Jutta Meise</p>
    </div>
  </section>


  <!-- Themen & Schwerpunkte -->
  <section style="background: var(--color-cream);" class="px-8 sm:px-14 lg:px-20 py-24 sm:py-32">
    <div class="max-w-6xl mx-auto">
      <p class="t-label-petrol mb-5">Schwerpunkte</p>
      <h2 class="t-heading mb-16" style="font-size: clamp(1.75rem, 3vw, 2.5rem);">Themen, die bewegen</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-10">
        {[
          { title: 'Frauenleben', text: 'Persönliche Geschichten, gelebte Erfahrungen, weibliche Perspektiven.' },
          { title: 'Sprache & Identität', text: 'Das Schreiben in zwei Sprachen als Heimat und Brücke.' },
          { title: 'Erinnerung', text: 'Was bleibt, was sich wandelt – Texte über Zeit und Gedächtnis.' },
          { title: 'Natur & Stille', text: 'Landschaft als Spiegel innerer Zustände.' },
          { title: 'Literarische Reflexion', text: 'Essays und Betrachtungen über Texte, Lesen und Schreiben.' },
          { title: 'Zweisprachigkeit', text: 'Publiziert auf Deutsch und Englisch – für ein internationales Lesepublikum.' },
        ].map(item => (
          <div style="border-top: 1px solid var(--color-petrol); padding-top: 1.25rem;">
            <h3 style="font-family: var(--font-serif); color: var(--color-ink); font-size: 1.0625rem; font-weight: 400; margin-bottom: 0.5rem;">{item.title}</h3>
            <p class="t-prose" style="font-size: 0.9rem;">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Stiller Abschluss -->
  <section style="background: var(--color-parchment); border-top: 1px solid var(--color-sand);" class="px-8 sm:px-14 lg:px-20 py-20">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row gap-8 items-start sm:items-end justify-between">
      <p style="font-family: var(--font-body); color: var(--color-subtle); font-style: italic; font-size: 0.9375rem;">
        Mehr über ihre Bücher und Veröffentlichungen.
      </p>
      <div class="flex gap-8">
        <a href="/buecher" class="text-link">Bücher →</a>
        <a href="/kontakt" class="text-link">Kontakt →</a>
      </div>
    </div>
  </section>

</BaseLayout>
